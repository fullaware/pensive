# Update and cp env.example .env

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@host.docker.internal:27017/?authSource=admin&directConnection=true

# LLM Configuration
LLM_URI=http://10.28.28.15:8080
LLM_EMBEDDING_URI=http://10.28.28.15:8080
LLM_MODEL=Qwen/Qwen3-Coder-Next-GGUF:Q4_K_M
LLM_EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b
# Note: Set EMBEDDING_DIMENSIONS to match your embedding model output
# text-embedding-nomic-embed-text-v1.5 returns 768 dimensions
EMBEDDING_DIMENSIONS=768

# Memory Configuration
SHORT_TERM_MEMORY_SIZE=10
EPISODIC_MEMORY_LIMIT=100
VECTOR_SEARCH_LIMIT=5

# API Configuration (for Docker)
API_HOST=0.0.0.0
API_PORT=8000

# Telegram Configuration
# Get your bot token from @BotFather on Telegram
# Leave empty to disable Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_UPDATE_METHOD=polling  # polling or webhook

# Telegram Access Control
# Comma-separated list of allowed Telegram user IDs
# If empty, all users can interact with the bot
# To restrict access, get user IDs by having users send /start to the bot
# Example: TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# Bot Owner Telegram User ID (for receiving unauthorized access notifications)
# If set, the bot owner will receive notifications when unauthorized users try to interact with the bot
TELEGRAM_BOT_OWNER_ID=

# SearXNG Web Search Configuration
SEARXNG_URI=http://zen.home.fullaware.com:8383
